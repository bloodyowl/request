{
  "name": "@bloodyowl/request",
  "version": "3.2.0",
  "description": "Wrapper for fetch with better data-structures",
  "type": "module",
  "main": "dist/src/Request.js",
  "types": "dist/src/Request.d.ts",
  "repository": "git@github.com:bloodyowl/request.git",
  "author": "Matthias Le Brun <bloodyowl@icloud.com>",
  "license": "MIT",
  "files": [
    "LICENSE",
    "dist/src",
    "README.md"
  ],
  "keywords": [
    "typescript",
    "boxed",
    "request",
    "xhr"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "prettier": {
    "trailingComma": "all",
    "semi": false
  },
  "scripts": {
    "build": "bun clean && tsc",
    "clean": "rm -rf dist",
    "format": "prettier '**/*' -u -w",
    "prepack": "bun test && bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@bloodyowl/boxed": "^3.3.1",
    "@types/bun": "1.3.11",
    "jsdom": "^24.0.0",
    "microbundle": "^0.15.1",
    "prettier": "^3.2.5",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@bloodyowl/boxed": ">=3.3.1"
  },
  "private": true
}
